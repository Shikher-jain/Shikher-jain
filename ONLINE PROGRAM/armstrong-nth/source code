#include <stdio.h>
int main()
{
    int num,n,temp,sum,a,f,l;
    printf("Enter the first and last Term:");
    scanf("%d %d",&f,&l);
    printf("The Armstrong number between Of %d to %d is:",f,l);
       for(n=f;n<=l;n++)
    {
        num=n;
        temp=n;
        sum=0;
        while(num!=0)
        {
            a=num%10;
            sum=sum+a*a*a;
            num=num/10;
        }
         if(sum==temp)
         printf("\n%d",temp);
    }
    
}
